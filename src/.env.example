# Copy this file to .env when setting up local development.
# Do not commit .env; it is ignored by Git and should contain local secrets only.
DEBUG=true
ENV=development

SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=1

MYSQL_USER=root
MYSQL_ROOT_PASSWORD=
DATABASE_URL=mysql+aiomysql://${MYSQL_USER}:${MYSQL_ROOT_PASSWORD}@127.0.0.1:3306/ai_video_prod?charset=utf8mb4
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_ECHO=false

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4

GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-5.1
GLM_RESOURCE_ID=

XFYUN_MAAS_API_KEY=
XFYUN_MAAS_BASE_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2
XFYUN_MAAS_MODEL=astron-code-latest
XFYUN_MAAS_RESOURCE_ID=
HIDREAM_APP_ID=
HIDREAM_API_KEY=
HIDREAM_API_SECRET=
HIDREAM_CREATE_URL=https://cn-huadong-1.xf-yun.com/v1/private/s3fd61810/create
HIDREAM_QUERY_URL=https://cn-huadong-1.xf-yun.com/v1/private/s3fd61810/query
HIDREAM_DEFAULT_RESOLUTION=2k
HIDREAM_DEFAULT_ASPECT_RATIO=9:16

SEEDANCE_API_KEY=
SEEDANCE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDANCE_MODEL=doubao-seedance-2-0-260128
SEEDANCE_RESOURCE_ID=
# Optional vendor aliases from Ark console / SDK examples:
# ARK_API_KEY=
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_VIDEO_MODEL=
# ARK_MODEL=
# ARK_RESOURCE_ID=

AI_HTTP_TIMEOUT=60
AI_MAX_RETRIES=2
AI_USE_PLACEHOLDER_WHEN_UNCONFIGURED=false

VIDEO_STORAGE_BACKEND=local
MEDIA_ROOT=runtime/media
MEDIA_URL_PREFIX=/media
MEDIA_BASE_URL=

GITHUB_STORAGE_OWNER=
GITHUB_STORAGE_REPO=
GITHUB_STORAGE_TOKEN=
GITHUB_STORAGE_RELEASE_TAG=video-assets

IPFS_API_URL=http://127.0.0.1:5001
IPFS_GATEWAY_URL=https://ipfs.io/ipfs
IPFS_PIN_ON_ADD=true

S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=
S3_OBJECT_PREFIX=videos
S3_PUBLIC_BASE_URL=

DAILY_BUDGET=1000
COST_WARNING_THRESHOLD=0.8
COST_ALERT_THRESHOLD=1.0
COST_CRITICAL_THRESHOLD=1.2

LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=runtime/logs/app.log

PROMETHEUS_ENABLED=true
METRICS_PORT=9090
