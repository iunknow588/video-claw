# Repository remote URLs used by scripts/git/get.ps1 and scripts/git/commit.ps1
# Copy this file to .env in the repository root and adjust values if needed.
# NOTE: .env is ignored by Git and should contain your local secrets only.

REPO_SSH_URL=git@github.com:<YOUR_USERNAME>/<YOUR_REPO>.git
REPO_HTTPS_URL=https://github.com/<YOUR_USERNAME>/<YOUR_REPO>.git
PREFERRED_REMOTE_URL=git@github.com:<YOUR_USERNAME>/<YOUR_REPO>.git

# Local runtime database override
DATABASE_URL=sqlite+aiosqlite:///runtime/local-dev.db
MYSQL_USER=root
MYSQL_ROOT_PASSWORD=

# Runtime AI provider configuration loaded by src/departments/CEO/core/config/__init__.py
# Hotspot retrieval uses real providers by default.
# Set HOTSPOT_PROVIDER_MODE=mock only for tests or local offline development.
HOTSPOT_PROVIDER_MODE=real
# Real web search on Xiaohongshu / Douyin currently requires a logged-in browser Cookie header.
XIAOHONGSHU_COOKIE=
DOUYIN_COOKIE=
XFYUN_MAAS_API_KEY=
XFYUN_MAAS_BASE_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2
XFYUN_MAAS_MODEL=astron-code-latest
XFYUN_MAAS_RESOURCE_ID=
HIDREAM_APP_ID=
HIDREAM_API_KEY=
HIDREAM_API_SECRET=
HIDREAM_CREATE_URL=https://cn-huadong-1.xf-yun.com/v1/private/s3fd61810/create
HIDREAM_QUERY_URL=https://cn-huadong-1.xf-yun.com/v1/private/s3fd61810/query
HIDREAM_DEFAULT_RESOLUTION=2k
HIDREAM_DEFAULT_ASPECT_RATIO=9:16
SEEDANCE_API_KEY=
SEEDANCE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDANCE_MODEL=doubao-seedance-2-0-260128
SEEDANCE_RESOURCE_ID=
# Optional vendor aliases from Ark console / SDK examples:
# ARK_API_KEY=
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_VIDEO_MODEL=
# ARK_MODEL=
# ARK_RESOURCE_ID=
