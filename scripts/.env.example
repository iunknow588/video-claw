# Repository remote URLs used by scripts/get.ps1 and scripts/commit.ps1
# Copy this file to scripts\.env and update values if needed.
# Optional: point the scripts at a repo root if it is not the parent of this folder.
# REPO_ROOT_OVERRIDE=E:\path\to\repo

REPO_SSH_URL=git@github.com:iunknow588/video-claw.git
REPO_HTTPS_URL=https://github.com/iunknow588/video-claw.git
PREFERRED_REMOTE_URL=git@github.com:iunknow588/video-claw.git
