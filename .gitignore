# Python bytecode and import caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Local environment config files containing secrets
.env
.env.*
!**/.env.example

# Test and tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Build artifacts
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
doc/_build/

# Local runtime leftovers
*.log
*.tmp
*.db-journal
runtime/logs/*
!runtime/logs/.gitkeep
runtime/media/audio/*
!runtime/media/audio/.gitkeep
runtime/media/renders/*
!runtime/media/renders/.gitkeep
runtime/media/subtitles/*
!runtime/media/subtitles/.gitkeep
runtime/media/videos/*
!runtime/media/videos/.gitkeep
src/preview.db
src/ceo_console_preview*.db
src/ceo_ui*.db*
